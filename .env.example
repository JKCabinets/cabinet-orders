# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://your-project.vercel.app
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# ─── Shopify (optional) ───────────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_WEBHOOK_SECRET=your_webhook_signing_secret

# ─── Cron job security ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
CRON_SECRET=generate_with_openssl_rand_base64_32

# ─── Upstash Redis (rate limiting) ────────────────────────────────────────────
# Get these from upstash.com → create a Redis database → REST API
# Without these, rate limiting falls back to in-memory (resets on cold start)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here
